/dts-v1/;
#include <nordic/nrf52833_qdaa.dtsi>

&pinctrl {
    pwm0_default: pwm0_default {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 5)>,  /* 红色 LED: P0.05 */
                    <NRF_PSEL(PWM_OUT1, 0, 11)>, /* 绿色 LED: P0.11 */
                    <NRF_PSEL(PWM_OUT2, 1, 9)>;  /* 蓝色 LED: P1.09 */
            nordic,drive-mode = <NRF_DRIVE_S0S1>;
            nordic,invert; 
        };
    };

    pwm0_sleep: pwm0_sleep {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 5)>,
                    <NRF_PSEL(PWM_OUT1, 0, 11)>,
                    <NRF_PSEL(PWM_OUT2, 1, 9)>;
            low-power-enable;
        };
    };

    spi3_default: spi3_default {
        group1 {
            psels = <NRF_PSEL(SPIM_MISO, 0, 2)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 28)>,
                    <NRF_PSEL(SPIM_SCK, 0, 29)>;
        };
    };

    spi3_sleep: spi3_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_MISO, 0, 2)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 28)>,
                    <NRF_PSEL(SPIM_SCK, 0, 29)>;
            low-power-enable;
        };
    };
};

/ {
    model = "nekonya_tracker_uf2";
    compatible = "nekonya_tracker_uf2";

    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,console = &cdc_acm_uart0;
        zephyr,shell-uart = &cdc_acm_uart0;
    };

    pwmleds {
        compatible = "pwm-leds";
        pwm_led0: pwm_led_0 {
            pwms = <&pwm0 0 PWM_MSEC(1) PWM_POLARITY_NORMAL>; /* 红色 */
        };
        pwm_led1: pwm_led_1 {
            pwms = <&pwm0 1 PWM_MSEC(1) PWM_POLARITY_NORMAL>; /* 绿色 */
        };
        pwm_led2: pwm_led_2 {
            pwms = <&pwm0 2 PWM_MSEC(1) PWM_POLARITY_NORMAL>; /* 蓝色 */
        };
    };


    leds {
        compatible = "gpio-leds";
        led0: led_0 {
            gpios = <&gpio0 5 GPIO_ACTIVE_HIGH>; /* 红色 P0.05 */
        };
        led1: led_1 {
            gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>; /* 绿色 P0.11 */
        };
        led2: led_2 {
            gpios = <&gpio1 9 GPIO_ACTIVE_HIGH>; /* 蓝色 P1.09 */
        };
    };

    buttons {
        compatible = "gpio-keys";
        
        button0: button_0 {
            gpios = <&gpio0 20 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
            label = "Push button switch 0";
        };

        chrg_pin: chrg_pin {
            gpios = <&gpio0 15 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
            label = "Charge Status (CHRG)";
        };
        
        stdby_pin: stdby_pin {
            gpios = <&gpio0 17 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
            label = "Charge Complete (STDBY)";
        };
        
        pwr_en_pin: pwr_en_pin {
            gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;
            label = "Power Enable (IMU & MAG)";
        };
    };

    aliases {
        sw0 = &button0;
        pwm-led0 = &pwm_led0; 
        pwm-led1 = &pwm_led1; 
        pwm-led2 = &pwm_led2; 
        led0 = &led0;
        led1 = &led1;
        led2 = &led2;
    };

    battery-divider {
        compatible = "voltage-divider";
        status = "okay";
        io-channels = <&adc 12>;
        output-ohms = <1>;
        full-ohms = <5>;
    };

    zephyr,user {
        int0-gpios = <&gpio0 3 0>;
        chg_gpios = <&gpio0 15 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;   // P0.15 = CHRG
        stby_gpios = <&gpio0 17 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;  // P0.17 = STDBY
        led0-gpios = <&gpio0 5 GPIO_ACTIVE_HIGH>;   /* 红色 P0.05 */
        led1-gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;  /* 绿色 P0.11 */
        led2-gpios = <&gpio1 9 GPIO_ACTIVE_HIGH>;   /* 蓝色 P1.09 */
        pwr-gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;    /* IMU & MAG 电源使能 P0.04 高电平启动 */
    };
};

&reg1 {
    regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&adc {
    status = "okay";
};

&gpiote {
    status = "okay";
};

&gpio0 {
    status = "okay";
};

&gpio1 {
    status = "okay";
};

&pwm0 {
    status = "okay";
    pinctrl-0 = <&pwm0_default>;
    pinctrl-1 = <&pwm0_sleep>;
    pinctrl-names = "default", "sleep";
};

zephyr_udc0: &usbd {
    compatible = "nordic,nrf-usbd";
    status = "okay";
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};

&wdt {
	status = "okay";
};


&nfct {
    status = "disabled";
};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    max-frequency = <DT_FREQ_M(24)>;
    pinctrl-0 = <&spi3_default>;
    pinctrl-1 = <&spi3_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 30 GPIO_ACTIVE_LOW>;

    imu_spi: imu_spi@0 {
        compatible = "vnd,spi-device";
        spi-max-frequency = <DT_FREQ_M(24)>;
        label = "imu-spi";
        reg = <0>;
    };
};